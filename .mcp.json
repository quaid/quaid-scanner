{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "zerodb": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/zerodb-mcp"
      ],
      "env": {
        "ZERODB_API_KEY": "${ZERODB_API_KEY}"
      }
    }
  }
}
